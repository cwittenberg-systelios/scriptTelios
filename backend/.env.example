# ════════════════════════════════════════════════════════════════
#  sysTelios KI-Dokumentation – Umgebungsvariablen
#  Kopiere diese Datei zu .env und passe die Werte an.
#
#  Docker (lokale Entwicklung / Produktion):
#    cp .env.example .env
#    docker compose up -d
#
#  RunPod (ohne Docker):
#    Wird automatisch vom runpod-start.sh erstellt.
# ════════════════════════════════════════════════════════════════

# ── LLM ──────────────────────────────────────────────────────────
# Docker:   http://ollama:11434  (Service-Name im Docker-Netzwerk)
# RunPod:   http://localhost:11434
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=mistral-nemo

# ── Whisper ───────────────────────────────────────────────────────
# WHISPER_DEVICE: cpu (ohne GPU) | cuda (mit NVIDIA-GPU)
# WHISPER_COMPUTE_TYPE: int8 (CPU) | float16 (GPU)
# Hinweis: Bei langen Aufnahmen (>30 Min) kann CUDA out-of-memory auftreten.
# In diesem Fall WHISPER_DEVICE=cpu und WHISPER_COMPUTE_TYPE=int8 setzen
# oder das Backend startet automatisch einen CPU-Fallback.
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

# Ollama vor Whisper aus VRAM entladen?
# False (Standard): Whisper + Ollama teilen VRAM – kein LLM-Kaltstart nach Transkription.
#   Empfohlen für RTX 4090 (24GB): large-v3 (~3GB) + mistral-nemo (~5GB) passen gleichzeitig.
# True: Für kleinere GPUs (<12GB) – Whisper bekommt den ganzen VRAM,
#   aber der erste LLM-Aufruf nach Transkription dauert ~20-30s (Kaltstart).
WHISPER_FREE_OLLAMA_VRAM=false

# ── Datenbank ─────────────────────────────────────────────────────
# Docker:   @db:5432        (Service-Name im Docker-Netzwerk)
# RunPod:   @127.0.0.1:5432 (direkt, kein Docker-Netzwerk)
# WICHTIG:  Kein ?sslmode= Parameter noetig – SSL wird in database.py
#           via connect_args={"ssl": False} deaktiviert.
DATABASE_URL=postgresql+asyncpg://systelios:systelios@db:5432/systelios

# ── Sicherheit ────────────────────────────────────────────────────
# Zufaelligen Key generieren:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=BITTE-AENDERN-VOR-PRODUKTIONSEINSATZ

# ── Datenschutz ───────────────────────────────────────────────────
# Audiodateien nach Transkription loeschen (empfohlen: true)
DELETE_AUDIO_AFTER_TRANSCRIPTION=true

# ── CORS ──────────────────────────────────────────────────────────
# Confluence-URL eintragen damit Anfragen vom Intranet erlaubt werden.
# Beispiel: http://intranet.systelios.local oder https://wiki.systelios.de
CONFLUENCE_URL=http://intranet.systelios.local

# Weitere erlaubte Origins (kommagetrennt):
# EXTRA_CORS_ORIGINS=https://mein-client.de

# RunPod-Proxy-Domain erlauben (Testphase):
# true  → https://*.proxy.runpod.net wird erlaubt
# false → nur explizit eingetragene Origins (Produktion)
ALLOW_RUNPOD_PROXY=false

# Cloudflare-Tunnel erlauben (Testphase via 'cloudflared tunnel --url ...'):
# true  → https://*.trycloudflare.com wird erlaubt
# false → nur explizit eingetragene Origins (Produktion)
ALLOW_CLOUDFLARE_TUNNEL=true

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=systelios.log
