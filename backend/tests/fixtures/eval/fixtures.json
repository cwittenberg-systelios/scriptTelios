      "expected": {
        "min_words": 350,
        "max_words": 650,
        "required_keywords": ["Verlängerung", "ambulant"],
        "forbidden_patterns": ["**", "##"],
        "must_contain_sections": ["Verlauf", "Verlängerung"]
      }
    }
  ],

  "anamnese": [
