      "expected": {
        "min_words": 550,
        "max_words": 900,
        "required_keywords": ["Anteile", "Trennung", "Gruppe", "ambulant"],
        "forbidden_patterns": ["**", "##", "Epikrise:", "Procedere:"],
        "must_contain_sections": ["Behandlungsverlauf", "Empfehlung"],
        "name_format": "Herr R.",
        "forbidden_names": ["Reif", "28032"]
      }
    }
  ],

  "verlaengerung": [
    {
      "id": "va-01-borderline-stabilisierung",
