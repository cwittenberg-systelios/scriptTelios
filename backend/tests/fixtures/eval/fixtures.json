{
  "description": "Evaluations-Fixtures fuer scriptTelios Qualitaetsmessung. 2 Testfaelle pro Workflow.",
  "version": "1.0",

  "entlassbericht": [
    {
      "id": "eb-01-depression-anteilearbeit",
      "name": "Depression mit Anteilearbeit (Frau)",
