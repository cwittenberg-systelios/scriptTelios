        "verlaufsdoku": "EB-FrauM/tpVerlaufsdokumentation.pdf"
      },
      "expected": {
        "min_words": 550,
        "max_words": 900,
        "required_keywords": ["Anteile", "Selbstwert", "Gruppe", "ambulant"],
        "forbidden_patterns": ["**", "##", "Epikrise:", "Procedere:", "I.", "II."],
        "must_contain_sections": ["Behandlungsverlauf", "Empfehlung"],
        "forbidden_names": ["Mayer", "Isdek", "A28094"]
