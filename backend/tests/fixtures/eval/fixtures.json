      "diagnosen": ["F32.1", "F60.8"],
      "expected": {
        "min_words": 550,
        "max_words": 900,
        "required_keywords": ["Anteile", "Selbstwert", "Gruppe", "ambulant"],
        "forbidden_patterns": ["**", "##", "Epikrise:", "Procedere:", "I.", "II."],
        "must_contain_sections": ["Behandlungsverlauf", "Empfehlung"],
        "name_format": "Frau M.",
        "forbidden_names": ["Mayer", "Isdek", "A28094"]
      }
    },
    {
      "id": "eb-02-ads-trennung",
      "name": "ADS und Paarkrise (Mann)",
      "prompt": "Schreibe den psychotherapeutischen Verlaufsteil des Entlassberichts. Schwerpunkte: Tuersteer-Anteil, raeumliche Trennung, Beziehungsdynamik, Kunsttherapie als Ressource.",
