      "diagnosen": ["F60.31", "F32.1"],
      "expected": {
        "min_words": 350,
        "max_words": 650,
        "required_keywords": ["Anteilearbeit", "Verlängerung", "Stabilität"],
        "forbidden_patterns": ["**", "##", "Diagnose:", "Stammdaten"],
        "must_contain_sections": ["Verlauf", "Verlängerung"]
